{
  "name": "dashdev",
  "version": "0.1.0",
  "description": "Local development dashboard — services, workflows, CI/CD, Redis, and git repos in one place",
  "repository": {
    "type": "git",
    "url": "https://github.com/sarthikbhat/devdash.git"
  },
  "keywords": ["devtools", "dashboard", "workflows", "services", "local-dev"],
  "license": "MIT",
  "author": "Sarthik Bhat",
  "type": "module",
  "files": [
    "bin/devdash.js",
    "dist/server/api/*.js",
    "dist/server/core/*.js",
    "dist/server/index.js",
    "dist/ui/**"
  ],
  "bin": {
    "dashdev": "./bin/devdash.js"
  },
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "dev:ui": "cd ui && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:ui\"",
    "build:ui": "cd ui && npm run build && cp -r dist ../dist/ui",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "ioredis": "^5.11.0",
    "js-yaml": "^4.1.0",
    "socket.io": "^4.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.0.0",
    "concurrently": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
