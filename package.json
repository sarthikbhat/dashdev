{
  "name": "devdash",
  "version": "0.1.0",
  "description": "Local web dashboard for running multi-step developer workflows",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "dev:ui": "cd ui && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:ui\"",
    "build:ui": "cd ui && npm run build",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "js-yaml": "^4.1.0",
    "socket.io": "^4.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.0.0",
    "concurrently": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
